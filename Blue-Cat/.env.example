# Variables de Entorno - Blue-Cat ERP
# Copiar este archivo a .env y configurar los valores

# =============================================================================
# BASE DE DATOS
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bluecat_erp
DB_USER=bluecat_user
DB_PASSWORD=

# =============================================================================
# APLICACIÓN
# =============================================================================
APP_NAME=Blue-Cat ERP
APP_ENV=production
APP_DEBUG=false
APP_URL=https://erp.dominio.com
FORCE_HTTPS=true
APP_TIMEZONE=America/Santiago
APP_LOCALE=es_CL

# =============================================================================
# SEGURIDAD
# =============================================================================
# Generar una clave única sin mostrarla en consola:
# php scripts/ensure-app-key.php
APP_KEY=
SESSION_LIFETIME=120
BCRYPT_ROUNDS=12

# CSRF
CSRF_TOKEN_NAME=csrf_token

# Rate Limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=300

# =============================================================================
# EMAIL (OPCIONAL)
# =============================================================================
MAIL_ENABLED=false
MAIL_HOST=smtp.dominio.com
MAIL_PORT=587
MAIL_USERNAME=noreply@dominio.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@dominio.com
MAIL_FROM_NAME=Blue-Cat ERP

# =============================================================================
# BACKUPS
# =============================================================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/opt/bluecat/backups
BACKUP_REMOTE_ENABLED=false
BACKUP_REMOTE_TYPE=s3
BACKUP_REMOTE_BUCKET=bluecat-backups
BACKUP_REMOTE_KEY=
BACKUP_REMOTE_SECRET=

# =============================================================================
# LOGS
# =============================================================================
LOG_LEVEL=INFO
LOG_PATH=/opt/bluecat/logs
LOG_MAX_SIZE=10M
LOG_MAX_FILES=10

# =============================================================================
# ALMACENAMIENTO
# =============================================================================
UPLOAD_MAX_SIZE=10M
UPLOAD_PATH=/opt/bluecat/app/assets/uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# =============================================================================
# MONITOREO
# =============================================================================
MONITORING_ENABLED=false
HEALTH_CHECK_ENDPOINT=/health
METRICS_ENABLED=false

# =============================================================================
# LICENCIA
# =============================================================================
LICENSE_KEY=
LICENSE_TYPE=production
MAX_USERS=100
EXPIRATION_DATE=

# =============================================================================
# DESARROLLO (SOLO DESARROLLO)
# =============================================================================
DEBUG_BAR=false
SQL_LOG=false
