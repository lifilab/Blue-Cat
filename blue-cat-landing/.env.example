NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_COMMERCIAL_EMAIL=ventas@tu-dominio.cl
DATABASE_URL=mysql://root@127.0.0.1:3306/blue_cat_commercial
# Se muestra solo después de registrar una solicitud válida.
BANK_TRANSFER_INSTRUCTIONS="Configurar beneficiario, banco, tipo y número de cuenta antes de operar."
PURCHASE_TOKEN_SECRET=replace-with-at-least-32-random-characters
# Si un precio no está definido, la solicitud queda pendiente de cotización y no muestra datos bancarios.
PYME_PRICE_MINOR=
ENTERPRISE_PRICE_MINOR=
COMMERCIAL_CURRENCY=CLP
COMMERCIAL_CURRENCY_DECIMALS=0
NEXT_PUBLIC_COMMERCIAL_CURRENCY_DECIMALS=0
OFFER_VERSION=
OFFER_VALID_DAYS=7
# Ruta absoluta o nombre de subdirectorio seguro dentro de storage/private/.
PAYMENT_EVIDENCE_DIR=payment-evidence
# API administrativa temporal; use al menos 32 caracteres aleatorios y restrinja el acceso por red.
ADMIN_API_TOKEN=replace-with-at-least-32-random-characters
ADMIN_ACTOR_ID=commercial-admin
